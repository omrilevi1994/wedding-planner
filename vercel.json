{
  "redirects": [
    {
      "source": "/(ActivityLog|AdminDashboard|Calculator|Checklist|Dashboard|Expenses|Gifts|Guests|Home|Payments|SeatingPlan|Settings|UserManagement|Vendors|WeddingMode)",
      "destination": "/app/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/app",
      "destination": "/app.html"
    },
    {
      "source": "/app/(.*)",
      "destination": "/app.html"
    },
    {
      "source": "/calc",
      "destination": "/calc.html"
    }
  ]
}
